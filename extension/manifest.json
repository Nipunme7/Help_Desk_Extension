{
  "manifest_version": 3,
  "name": "Help Desk Ticket Watch",
  "version": "0.1.0",
  "description": "Warns when someone else on the help desk is viewing the same ticket.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Help Desk"
  },
  "content_scripts": [
    {
      "matches": ["*://help.luther.edu/adminui/ticket.php*"],
      "js": ["content/userinfo.js"]
    }
  ]
}
